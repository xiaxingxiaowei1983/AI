  "methods": {
    "getJieQiTime": "function(year, jieqiName) { const yearData = this.data[year]; if (yearData && yearData[jieqiName]) { return new Date(yearData[jieqiName]); } return null; }",
    "getYearJieQi": "function(year) { return this.data[year] || null; }",
    "hasYearData": "function(year) { return !!this.data[year]; }",
    "getNearestJieQi": "function(date) { const year = date.getFullYear(); const month = date.getMonth() + 1; const day = date.getDate(); let nearestJieQi = null; let minDiff = Infinity; const yearData = this.data[year]; if (yearData) { for (const [name, timeStr] of Object.entries(yearData)) { const jieqiDate = new Date(timeStr); const diff = Math.abs(jieqiDate - date); if (diff < minDiff) { minDiff = diff; nearestJieQi = { name, date: jieqiDate }; } } } return nearestJieQi; }",
    "getReferenceData": "function(dateStr) { return this.reference_data[dateStr] || null; }",
    "hasReferenceData": "function(dateStr) { return !!this.reference_data[dateStr]; }"
  }
