{
  "model": {
    "provider": "alibaba-bailian",
    "useInternalModel": false,
    "modelName": "qwen3.5-plus",
    "apiKey": "env:ALIBABA_CLOUD_API_KEY",
    "apiBase": "https://dashscope.aliyuncs.com/compatible-mode/v1",
    "region": "cn-beijing",
    "parameters": {
      "temperature": 0.7,
      "topP": 0.8,
      "maxTokens": 2048
    }
  },
  "evo": {
    "enable": true,
    "review": true,
    "autoImprove": true
  },
  "agent": {
    "autoRun": true,
    "continuousMode": true
  },
  "workspace": {
    "autoClean": false,
    "backup": true
  }
}