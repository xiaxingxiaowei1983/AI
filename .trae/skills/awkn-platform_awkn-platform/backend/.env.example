# 服务器配置
NODE_ENV=production
PORT=4000

# 前端URL
FRONTEND_URL=http://localhost:3000

# 数据库配置
MONGODB_URI=mongodb://localhost:27017/awkn

# JWT密钥
JWT_SECRET=your-jwt-secret-key-change-in-production

# AI服务配置（根据实际使用的AI服务填写）
# OpenAI
OPENAI_API_KEY=your-openai-api-key

# Stable Diffusion
STABLE_DIFFUSION_API_URL=https://api.stability.ai
STABLE_DIFFUSION_API_KEY=your-stability-api-key

# 文件存储（S3或阿里云OSS）
# AWS S3
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=awkn-uploads

# 或阿里云OSS
ALIYUN_ACCESS_KEY_ID=your-aliyun-access-key
ALIYUN_ACCESS_KEY_SECRET=your-aliyun-secret-key
ALIYUN_OSS_BUCKET=awkn-uploads
ALIYUN_OSS_REGION=oss-cn-hangzhou

# 速率限制
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
