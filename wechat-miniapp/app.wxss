page {
  background: #0b0b0b;
  color: #f5f5f5;
  font-size: 28rpx;
}

.container {
  padding: 24rpx;
}

.card {
  background: linear-gradient(135deg, #171717, #0f0f0f);
  border: 1rpx solid #2b2b2b;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
  color: #d4af37;
}

.subtitle {
  color: #b8b8b8;
  margin-bottom: 12rpx;
}

.btn {
  margin-top: 16rpx;
  background: #d4af37;
  color: #111;
}
