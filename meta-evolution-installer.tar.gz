{"code":99991672,"msg":"Access denied. One of the following scopes is required: [drive:drive, drive:drive:readonly, drive:file:readonly, drive:file, drive:file:download].应用尚未开通所需的应用身份权限：[drive:drive, drive:drive:readonly, drive:file:readonly, drive:file, drive:file:download]，点击链接申请并开通任一权限即可：https://open.feishu.cn/app/cli_a91012cd0ab89bc9/auth?q=drive:drive,drive:drive:readonly,drive:file:readonly,drive:file,drive:file:download&op_from=openapi&token_type=tenant","error":{"log_id":"2026022823482040E548C7ED54E6E01847","troubleshooter":"排查建议查看(Troubleshooting suggestions): https://open.feishu.cn/search?from=openapi&log_id=2026022823482040E548C7ED54E6E01847&code=99991672&method_id=6944991842538733569","permission_violations":[{"subject":"drive:drive","type":"action_scope_required"},{"type":"action_scope_required","subject":"drive:drive:readonly"},{"type":"action_scope_required","subject":"drive:file:readonly"},{"type":"action_scope_required","subject":"drive:file"},{"type":"action_scope_required","subject":"drive:file:download"}],"message":"Refer to the documentation to fix the error: https://open.feishu.cn/document/uAjLw4CM/ugTN1YjL4UTN24CO1UjN/trouble-shooting/how-to-fix-the-99991672-error"}}