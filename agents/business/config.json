          "business",
          "coo",
          "master"
        ],
        "response_time": "30m",
        "communication_channels": [
          "emergency_meeting",
          "direct_message"
        ]
      },
      "compliance_breach": {
        "escalation_path": [
          "business",
          "legal",
          "master"
        ],
        "response_time": "24h",
        "communication_channels": [
          "legal_meeting",
          "direct_message"
        ]
      }
    },
    "crisis_management": {
      "scenarios": [
        "market_crash",
        "competitive_threat",
        "regulatory_changes",
        "compliance_breach",
        "reputational_crisis"
      ],
      "playbooks": {
        "market_crisis": "market_crisis_playbook",
        "compliance_crisis": "compliance_crisis_playbook",
        "reputational_crisis": "reputational_crisis_playbook"
      }
