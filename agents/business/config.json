      "compliance_action",
      "market_opportunity_evaluation",
      "competitive_strategy_adjustment"
    ],
    "escalation_paths": {
      "high_risk_issue": "master",
      "compliance_violation": "master",
      "market_crisis": "master",
      "resource_shortage": "coo"
