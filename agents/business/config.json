{
  "agent": {
    "type": "business",
    "autoRun": true
  },
  "company_context": {
    "name": "AWKN LAB | 定数实验室",
    "mission": "在不确定的世界里，为用户交付确定性",
    "slogan": "命运如水流动，你当不动如山。",
    "framework": {
      "A": "AWAKEN - 看清未来，不再迷茫。人生系统的风控雷达",
      "W": "WIRED - 看清过去真我，找回本能。潜意识的可视化投影，发掘天赋原厂说明书",
      "K": "KEY - 找到人生之钥，破开局势。认知军火库，模拟推演决策，寻找第二曲线",
      "N": "NOW - 开启新生旅程，就在此刻。每日行动指引，开启人生外挂"
    }
  },
  "startup": {
    "enabled": true,
    "priority": "high",
    "dependencies": [],
    "init_commands": [
      "load_company_context",
      "initialize_risk_system",
      "connect_agent_network"
    ]
  },
  "server": {
    "port": 4004,
    "host": "localhost"
  },
  "communication": {
    "protocols": [
      "direct_message",
      "group_message",
      "market_alert",
      "compliance_alert",
      "status_update"
    ],
    "response_time": "12s",
    "message_format": {
      "market_alert": "[市场预警] 事件: {event}\n影响: {impact}\n风险等级: {risk_level}\n建议: {suggestion}",
      "compliance_issue": "[合规问题] 问题: {issue}\n描述: {description}\n风险: {risk}\n整改建议: {recommendation}",
      "market_insight": "[市场洞察] 趋势: {trend}\n分析: {analysis}\n机会: {opportunity}\n威胁: {threat}"
    }
  },
  "tasks": {
    "types": [
      "market_monitoring",
      "competitive_analysis",
      "risk_assessment",
      "compliance_audit",
      "market_research",
      "business_intelligence",
      "reporting"
    ],
    "priorities": [
      "critical",
      "high",
      "medium",
      "low"
    ],
    "statuses": [
      "pending",
      "in_progress",
      "completed",
      "on_hold",
      "cancelled"
    ],
    "deadline_formats": [
      "yyyy-MM-dd",
      "yyyy-MM-dd HH:mm",
      "relative"
    ]
  },
  "workflow": {
    "steps": [
      "data_collection",
      "data_analysis",
      "risk_assessment",
      "compliance_check",
      "insight_generation",
