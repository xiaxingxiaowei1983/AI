  "model": {
    "provider": "trea",
    "useInternalModel": true,
    "optimization": {
      "enableCache": true,
      "cacheSize": 100,
      "enableStreaming": true
    },
    "session": {
      "maxHistory": 50,
      "enableSummary": true,
      "summaryThreshold": 20
    }
  },
  "evo": {
    "enable": true,
    "review": true,
    "autoImprove": false
  }
